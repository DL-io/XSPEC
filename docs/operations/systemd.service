[Unit]
Description=POLY-SHORE OMEGA X PM2 process group
After=network.target

[Service]
Type=forking
User=polyshore
WorkingDirectory=/opt/poly-shore-omega-x
ExecStart=/usr/bin/pm2 start ecosystem.config.cjs
ExecReload=/usr/bin/pm2 reload ecosystem.config.cjs
ExecStop=/usr/bin/pm2 delete ecosystem.config.cjs
Restart=on-failure

[Install]
WantedBy=multi-user.target
