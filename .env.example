NODE_ENV=production
OPERATING_MODE=paper

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string — Railway, PlanetScale, or self-hosted
DATABASE_URL=mysql://user:password@host:3306/polyshore

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use rediss:// for TLS (required for Upstash and most hosted providers)
REDIS_URL=rediss://default:password@host:6379

# ── Security ──────────────────────────────────────────────────────────────────
# At least 32 random characters each — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-characters
ENCRYPTION_KEY=replace-with-at-least-32-characters

# ── Terminal ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TENANT_ID=system
# Generated by `pnpm bootstrap` on first launch — leave blank to auto-generate
NEXT_PUBLIC_OPERATOR_API_KEY=

# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Required only for live order execution (paper mode does not need these)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137

# ── Kalshi ────────────────────────────────────────────────────────────────────
# Production endpoint (external API gateway — preferred)
KALSHI_API_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
# Legacy fallback — KALSHI_API_BASE_URL takes precedence if both are set
KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2
# Your Kalshi API key ID (also shown as KALSHI_API_KEY_ID in the Kalshi dashboard)
KALSHI_KEY_ID=
# RSA private key PEM inline — paste entire key including header/footer (also: KALSHI_PRIVATE_KEY_PEM)
KALSHI_PRIVATE_KEY=
# Alternative: path to RSA private key file (used when inline PEM not set)
KALSHI_PRIVATE_KEY_PATH=

# ── Live Trading Safeguards ───────────────────────────────────────────────────
LIVE_TRADING_ENABLED=false
KILLSWITCH_ARMED=false

# ── LLM Research Providers ───────────────────────────────────────────────────
# Tier 1 — Ollama (local, always-on primary). Install: https://ollama.ai
# Pull model with: ollama pull gemma3:27b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b

# Tier 2 — Groq (cloud fallback / high-reasoning). Get key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tier 3 — Gemini (OpenAI-compatible endpoint). Get key: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional additional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
RESEARCH_PROVIDERS_REQUIRED=false

# ── Venue Selection ───────────────────────────────────────────────────────────
# Comma-separated list of active venues: kalshi, polymarket, or kalshi,polymarket
ACTIVE_VENUES=kalshi

# ── Risk & Mandate Config ────────────────────────────────────────────────────
# Available: ultra_conservative, conservative, balanced, aggressive, micro
# Use 'micro' for small bankroll ($15–$50) — enforces $3 trade cap, $10 reserve floor
MANDATE_ID=micro
ACTIVE_MANDATE=micro
DAILY_LOSS_LIMIT=3
DRAWDOWN_LIMIT=0.10
MAX_OPEN_ORDERS=5
MAX_PARTICIPATION_RATE=0.05

# ── Worker Timing ─────────────────────────────────────────────────────────────
STRICT_RESOLUTION_MODE=true
WATCHLIST_POLL_SECONDS=5
ACTIVE_MARKET_POLL_SECONDS=15
RECONCILIATION_SECONDS=30

# ── Alerting ──────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
SMTP_URL=
SMS_WEBHOOK_URL=

# ── Network / Security ───────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the terminal API
ALLOWED_ORIGINS=https://terminal.example.com
# Set true ONLY for local single-operator use — bypasses API key requirement
TRUST_OPERATOR_ROLE_HEADERS=false
# Number of trusted proxy hops for IP extraction (0 = direct connection)
TRUSTED_PROXY_HOPS=0

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set true to serve synthetic data — no DB or Redis required for dashboard preview
DEMO_MODE=false
