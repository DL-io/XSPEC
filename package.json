{
  "name": "poly-shore-omega-x",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @polyshore/terminal dev",
    "check": "./node_modules/.bin/tsc -b --noEmit && ./node_modules/.bin/vitest run",
    "build": "./node_modules/.bin/tsc -b --noEmit && pnpm --filter @polyshore/terminal build",
    "typecheck": "./node_modules/.bin/tsc -b --noEmit",
    "test": "./node_modules/.bin/vitest run",
    "db:generate": "./node_modules/.bin/drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "./node_modules/.bin/drizzle-kit migrate --config drizzle.config.ts",
    "db:check": "./node_modules/.bin/vitest run packages/db/src/migrations.test.ts",
    "preflight": "./node_modules/.bin/tsx scripts/preflight.ts",
    "seed": "./node_modules/.bin/tsx scripts/seed.ts",
    "simulate": "./node_modules/.bin/tsx scripts/simulate.ts",
    "validate-config": "./node_modules/.bin/tsx scripts/validate-config.ts"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "mysql2": "^3.11.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
